module FunctionFile scope=0 workspace=0
  function workspace_receiver_handle scope=1 workspace=1 captures=[]
    inputs [binding(name=s kind=parameter binding=2 storage=local)]
    outputs [binding(name=y kind=output binding=3 storage=local)]
    assign [binding(name=f kind=variable binding=4 storage=local)] = handle_expr(field(field(value(name=s resolution=workspace_value binding=2 kind=parameter), item), total))
    assign [binding(name=y kind=output binding=3 storage=local)] = value(name=f resolution=workspace_value binding=4 kind=variable)
