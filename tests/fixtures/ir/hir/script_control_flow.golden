module Script scope=0 workspace=0
  assign [binding(name=a kind=variable binding=1 storage=local)] = number(1)
  assign [binding(name=b kind=variable binding=2 storage=local)] = number(2)
  assign [binding(name=c kind=variable binding=3 storage=local)] = number(3)
  assign [binding(name=d kind=variable binding=4 storage=local)] = number(4)
  assign [binding(name=x kind=variable binding=5 storage=local)] = matrix[value(name=a resolution=workspace_value binding=1 kind=variable), value(name=b resolution=workspace_value binding=2 kind=variable) ; value(name=c resolution=workspace_value binding=3 kind=variable), value(name=d resolution=workspace_value binding=4 kind=variable)]
  assign [binding(name=mode kind=variable binding=6 storage=local)] = number(1)
  switch value(name=mode resolution=workspace_value binding=6 kind=variable)
    case number(0)
      assign [binding(name=y kind=variable binding=7 storage=local)] = call(callable(name=zeros semantic=builtin_function final=builtin_function), [number(1), number(2)])
    otherwise
      assign [binding(name=y kind=variable binding=7 storage=local)] = call(callable(name=sum semantic=builtin_function final=builtin_function), [value(name=x resolution=workspace_value binding=5 kind=variable)])
  end_switch
