module FunctionFile scope=0 workspace=0
  function receiver_expression_handle scope=1 workspace=1 captures=[]
    inputs [binding(name=objs kind=parameter binding=2 storage=local), binding(name=s kind=parameter binding=3 storage=local)]
    outputs [binding(name=y kind=output binding=4 storage=local)]
    assign [binding(name=f0 kind=variable binding=5 storage=local)] = handle_expr(field(field(value(name=s resolution=workspace_value binding=3 kind=parameter), item), total))
    assign [binding(name=f1 kind=variable binding=6 storage=local)] = handle_expr(field(cell_index(value(name=objs resolution=workspace_value binding=2 kind=parameter), [number(2)]), total))
    assign [binding(name=f2 kind=variable binding=7 storage=local)] = handle_expr(field(call_expr(call_expr(field(value(name=objs resolution=workspace_value binding=2 kind=parameter), duplicate), []), [number(3)]), total))
    assign [binding(name=y kind=output binding=4 storage=local)] = value(name=f0 resolution=workspace_value binding=5 kind=variable)
